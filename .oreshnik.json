{
  "version": 1,
  "project": {
    "name": "HeptaCore",
    "mainBranch": "master"
  },
  "operators": [
    {
      "id": "manuel",
      "displayName": "Manuel Vera",
      "name": "Manuel Vera",
      "email": "manuel@heptacore.dev",
      "projectRole": "owner",
      "status": "active"
    },
    {
      "id": "jean",
      "displayName": "Jean",
      "name": "Jean",
      "email": "jean@heptacore.dev",
      "projectRole": "operator",
      "status": "active"
    },
    {
      "id": "codex",
      "displayName": "Codex Agent",
      "name": "Codex Agent",
      "projectRole": "operator",
      "status": "active"
    }
  ],
  "branching": {
    "motherPrefix": "MADRE",
    "childFormat": "{operator}/{sprint}-{desc}-{date}",
    "integrationPrefix": "integration"
  },
  "validation": {
    "gates": [
      {
        "name": "typecheck",
        "command": "npm",
        "args": [
          "run",
          "typecheck"
        ],
        "timeoutSeconds": 120
      },
      {
        "name": "build",
        "command": "npm",
        "args": [
          "run",
          "build"
        ],
        "timeoutSeconds": 300
      },
      {
        "name": "worker",
        "command": "npm",
        "args": [
          "run",
          "worker:validate"
        ],
        "timeoutSeconds": 120
      }
    ]
  },
  "hardStops": {
    "forbiddenPatterns": [],
    "doubleLockPatterns": []
  },
  "vault": {
    "enabled": true,
    "path": "docs/obsidian-vault",
    "centralDoc": "00_CENTRAL.md"
  },
  "canonical": {
    "derivedDocs": [
      {
        "path": "docs/obsidian-vault/00_CENTRAL_HEPTACORE.md",
        "type": "central",
        "source": "task-board"
      },
      {
        "path": "docs/obsidian-vault/COLABORADORES/ESTADO_MANUEL.md",
        "type": "collaborator",
        "source": "task-board",
        "filter": {
          "owner": "Manuel"
        }
      },
      {
        "path": "docs/obsidian-vault/COLABORADORES/ESTADO_JEAN.md",
        "type": "collaborator",
        "source": "task-board",
        "filter": {
          "owner": "Jean"
        }
      },
      {
        "path": "docs/obsidian-vault/PRODUCT/STATUS_BOARD.md",
        "type": "status-board",
        "source": "task-board"
      }
    ]
  },
  "checkpoints": {
    "autoOnClose": true,
    "autoPreRollback": true,
    "snapshotDir": "var/oreshnik/checkpoints"
  },
  "security": {
    "requireCleanTree": true,
    "secretScanning": true,
    "blockEnvDiffs": true
  }
}
