# PostgreSQL (required)
# Use pooled connection for DATABASE_URL (PgBouncer/Supavisor/Neon pool)
# Use direct (non-pooled) connection for DIRECT_URL (Prisma migrations)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Redis (required for BullMQ worker queue)
# Local: redis://localhost:6379
# Upstash: rediss://user:pass@host:port
# Railway: provided automatically as REDIS_URL
# See docs/06_operations/worker-hosting-plan.md
REDIS_URL="redis://localhost:6379"

# Auth (required)
# Generate with: openssl rand -base64 32
AUTH_SECRET="changeme"

# Tenant
HEPTACORE_TENANT_SLUG="turpial"
HEPTACORE_ADMIN_EMAIL="admin@heptacore.dev"
HEPTACORE_ADMIN_PASSWORD="changeme"
HEPTACORE_ADMIN_ROLE="SUPER_ADMIN"

# Worker / Publishing
# PUBLISHING_HARD_STOP: true = dry-run only, false = real publishing allowed when PUBLISHING_REAL_ENABLED=true
# PUBLISHING_REAL_ENABLED: false = blocked, true = real publishing gate open
# PUBLISHING_REQUIRE_MANUAL_APPROVAL: true = operator checkbox required before publish
BOT_MODE="draft"
PUBLISHING_HARD_STOP="true"
PUBLISHING_REAL_ENABLED="false"
PUBLISHING_REQUIRE_MANUAL_APPROVAL="true"

LLM_PROVIDER="deterministic"
LLM_PROVIDER_API_KEY=""
LLM_MODEL=""
