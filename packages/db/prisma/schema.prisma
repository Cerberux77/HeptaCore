generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id              String                @id @default(cuid())
  slug            String                @unique
  name            String
  plan            TenantPlan            @default(PILOT)
  automationMode  AutomationMode        @default(DRAFT_ONLY)
  llmConfig       Json?
  costConfig      Json?
  status          TenantStatus          @default(PROVISIONING)
  timezone        String                @default("UTC")
  locale          String                @default("es")
  suspendedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  approvals       Approval[]
  assets          Asset[]
  auditLogs       AuditLog[]
  BrandProfile    BrandProfile[]
  campaigns       Campaign[]
  drafts          ContentDraft[]
  ContentPillar   ContentPillar[]
  credentials     CredentialVaultItem[]
  interactions    Interaction[]
  Invitation      Invitation[]
  leads           Lead[]
  memberships     Membership[]
  OAuthConnection OAuthConnection[]
  projects        Project[]
  PublishingJob   PublishingJob[]
  reports         Report[]
  socialAccounts  SocialAccount[]
  StrategyBrief   StrategyBrief[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  passwordHash String?
  approvals    Approval[]   @relation("ApprovalReviewer")
  auditLogs    AuditLog[]
  Invitation   Invitation[]
  memberships  Membership[]
}

model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

model Project {
  id             String         @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  offer          String?
  audience       Json?
  valueProps     Json?
  constraints    Json?
  strategyBrief  Json?
  onboardingDone Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assets         Asset[]
  drafts         ContentDraft[]
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports        Report[]

  @@index([tenantId])
}

model Asset {
  id           String              @id @default(cuid())
  tenantId     String
  projectId    String?
  kind         AssetKind
  sourcePath   String?
  storageKey   String?
  filename     String
  mimeType     String?
  metadata     Json?
  rightsStatus String              @default("needs_review")
  createdAt    DateTime            @default(now())
  project      Project?            @relation(fields: [projectId], references: [id])
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  drafts       ContentDraftAsset[]

  @@index([tenantId, kind])
  @@index([projectId])
}

model SocialAccount {
  id                String            @id @default(cuid())
  tenantId          String
  network           SocialNetwork
  handle            String?
  externalAccountId String?
  status            String            @default("disconnected")
  scopes            String[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  campaigns         Campaign[]
  drafts            ContentDraft[]
  interactions      Interaction[]
  OAuthConnection   OAuthConnection[]
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, network, externalAccountId])
  @@index([tenantId, network])
}

model CredentialVaultItem {
  id              String    @id @default(cuid())
  tenantId        String
  socialAccountId String?
  provider        String
  label           String
  encryptedBlob   Bytes
  keyVersion      String
  expiresAt       DateTime?
  rotatedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, provider])
}

model ContentDraft {
  id              String              @id @default(cuid())
  tenantId        String
  projectId       String?
  socialAccountId String?
  network         SocialNetwork
  format          String
  title           String
  caption         String
  hashtags        String[]
  cta             String?
  pillar          String?
  status          ApprovalStatus      @default(DRAFT)
  riskLevel       String              @default("low")
  requiresReview  Boolean             @default(true)
  scheduledFor    DateTime?
  publishedAt     DateTime?
  externalPostId  String?
  source          String?
  sortOrder       Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  approvals       Approval[]
  project         Project?            @relation(fields: [projectId], references: [id])
  socialAccount   SocialAccount?      @relation(fields: [socialAccountId], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets          ContentDraftAsset[]
  metrics         MetricSnapshot[]
  PublishingJob   PublishingJob[]

  @@index([tenantId, network, status])
  @@index([tenantId, scheduledFor])
}

model ContentDraftAsset {
  id      String       @id @default(cuid())
  draftId String
  assetId String
  role    String       @default("primary")
  asset   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  draft   ContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, assetId, role])
}

model Approval {
  id         String         @id @default(cuid())
  tenantId   String
  draftId    String?
  reviewerId String?
  status     ApprovalStatus
  reason     String?
  createdAt  DateTime       @default(now())
  draft      ContentDraft?  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  reviewer   User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id])
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Interaction {
  id              String         @id @default(cuid())
  tenantId        String
  socialAccountId String?
  network         SocialNetwork
  externalId      String?
  authorHandle    String?
  body            String
  sentiment       String?
  topic           String?
  riskLevel       String         @default("low")
  responseDraft   String?
  status          String         @default("new")
  createdAt       DateTime       @default(now())
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, network, status])
}

model Campaign {
  id              String         @id @default(cuid())
  tenantId        String
  socialAccountId String?
  network         SocialNetwork
  name            String
  objective       String
  platformBudget  Decimal        @db.Decimal(12, 2)
  overheadRate    Decimal        @default(0.35) @db.Decimal(4, 2)
  totalCharge     Decimal        @db.Decimal(12, 2)
  status          CampaignStatus @default(PROPOSED)
  recommendation  Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  source    String
  name      String?
  contact   String?
  company   String?
  score     Int      @default(0)
  consent   String   @default("unknown")
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, source])
}

model MetricSnapshot {
  id         String        @id @default(cuid())
  draftId    String?
  metric     String
  value      Decimal       @db.Decimal(18, 4)
  capturedAt DateTime      @default(now())
  draft      ContentDraft? @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId, capturedAt])
}

model Report {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  type      String
  period    String
  payload   Json
  sentTo    Json?
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, period])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  actorId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, action])
  @@index([actorId])
}

model EmailDelivery {
  id                String                 @id @default(cuid())
  tenantId          String?
  invitationId      String?
  userId            String?
  type              TransactionalEmailType
  provider          String
  providerMessageId String?                @unique
  idempotencyKey    String                 @unique
  recipient         String
  sender            String
  subject           String
  status            EmailDeliveryStatus    @default(PENDING)
  attemptCount      Int                    @default(0)
  lastErrorCode     String?
  lastErrorMessage  String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  bouncedAt         DateTime?
  complainedAt      DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([idempotencyKey])
  @@index([tenantId, type])
  @@index([providerMessageId])
}

model EmailWebhookEvent {
  id                String   @id @default(cuid())
  providerEventId   String   @unique
  providerMessageId String?
  type              String
  occurredAt        DateTime
  receivedAt        DateTime @default(now())

  @@index([providerMessageId])
}

model BrandProfile {
  id                    String   @id
  tenantId              String
  brandName             String
  industry              String?
  servicesProducts      Json?
  targetAudience        Json?
  geography             String?
  toneOfVoice           Json?
  socialChannels        Json?
  competitors           Json?
  assetAvailability     Json?
  approvalContact       Json?
  publishingPermissions Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  Tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContentPillar {
  id          String   @id
  tenantId    String
  name        String
  description String?
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Invitation {
  id           String    @id
  tenantId     String
  email        String
  role         UserRole
  tokenHash    String
  acceptedById String?
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  User         User?     @relation(fields: [acceptedById], references: [id])
  Tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model OAuthConnection {
  id              String         @id
  tenantId        String
  socialAccountId String?
  provider        OAuthProvider
  providerUserId  String?
  scopes          String[]
  status          String         @default("pending")
  tokenRef        String?
  expiresAt       DateTime?
  connectedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  SocialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id])
  Tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, provider, status])
}

model PublishingJob {
  id                       String            @id
  tenantId                 String
  postId                   String?
  provider                 OAuthProvider
  status                   ContentStatus     @default(SCHEDULED)
  scheduledFor             DateTime?
  attempts                 Int               @default(0)
  lastError                String?
  claimedAt                DateTime?
  claimToken               String?
  providerAttemptStartedAt DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime
  ContentDraft             ContentDraft?     @relation(fields: [postId], references: [id])
  Tenant                   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  PublishingResult         PublishingResult?

  @@index([tenantId, provider, status])
  @@index([status, scheduledFor])
  @@index([status, claimedAt])
}

model PublishingResult {
  id             String        @id
  jobId          String        @unique
  provider       OAuthProvider
  externalPostId String?
  ok             Boolean
  response       Json?
  createdAt      DateTime      @default(now())
  PublishingJob  PublishingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model StrategyBrief {
  id             String        @id
  tenantId       String
  title          String
  status         ContentStatus @default(DRAFT)
  businessGoals  Json?
  positioning    Json?
  audience       Json?
  channels       Json?
  assetChecklist Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  Tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  DISABLED
  DELAYED
  FAILED
  BOUNCED
  COMPLAINED
}

enum TransactionalEmailType {
  TENANT_OWNER_INVITATION
  TENANT_ACCESS_GRANTED
  MEMBER_INVITATION
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantPlan {
  PILOT
  GROWTH
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  STRATEGIST
  EDITOR
  ANALYST
  APPROVER
  VIEWER
  SUPER_ADMIN
  TENANT_ADMIN
  PUBLISHER
}

enum SocialNetwork {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
  LINKEDIN
  X
}

enum AutomationMode {
  DRAFT_ONLY
  APPROVAL_REQUIRED
  AUTOPILOT_LIMITED
  AUTOPILOT_FULL
}

enum ApprovalStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum AssetKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOGO
  BRAND_REFERENCE
}

enum CampaignStatus {
  PROPOSED
  NEEDS_APPROVAL
  APPROVED
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum OAuthProvider {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
}
