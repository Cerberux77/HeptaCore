{
  "name": "heptacore",
  "version": "0.1.0",
  "private": true,
  "description": "HeptaCore multi-tenant AI marketing operating system.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npx prisma generate",
    "dev": "npm run dev -w @heptacore/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:infra": "node --test scripts/goal-runner/__tests__/*.test.mjs scripts/oreshnik/__tests__/*.test.mjs",
    "test": "node --test apps/web/lib/calendar-state.test.mjs && npm run test:infra && npm run test --workspaces --if-present",
    "worker": "npm run start -w @heptacore/worker",
    "worker:validate": "npm run validate -w @heptacore/worker",
    "auth:ensure-access": "node scripts/ensure-user-access.mjs",
    "worker:report": "npm run report -w @heptacore/worker",
    "db:generate": "npm run db:generate -w @heptacore/db",
    "db:migrate": "npm run db:migrate -w @heptacore/db",
    "oreshnik:preflight": "oreshnik preflight",
    "oreshnik:status": "oreshnik status",
    "oreshnik:lock": "oreshnik lock",
    "oreshnik:zone": "oreshnik zone-check",
    "oreshnik:tasks": "oreshnik dashboard",
    "oreshnik:evidence": "oreshnik evidence --check",
    "oreshnik:close": "oreshnik close",
    "oreshnik:gate": "oreshnik gate",
    "oreshnik:timeline": "oreshnik timeline",
    "oreshnik:checkpoint": "oreshnik checkpoint",
    "oreshnik:integrate": "oreshnik integrate",
    "oreshnik:dispatch:init": "oreshnik dispatch init",
    "oreshnik:dispatch:status": "oreshnik dispatch status",
    "oreshnik:goal": "node scripts/oreshnik/goal.mjs",
    "oreshnik:canonical": "node scripts/oreshnik/canonical-check.mjs",
    "oreshnik:sync": "node scripts/oreshnik/sync-from-mother.mjs",
    "oreshnik:sync:latest": "node scripts/oreshnik/sync-latest-mother.mjs",
    "oreshnik:obsidian-guard": "node scripts/oreshnik/obsidian-guard.mjs",
    "oreshnik:ready": "node scripts/oreshnik/ready.mjs",
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "oreshnik:drift": "node scripts/oreshnik/drift.mjs",
    "oreshnik:drift:check": "node scripts/oreshnik/drift.mjs --check",
    "oreshnik:hook:install": "node -e \"const{cpSync}=require('fs');cpSync('scripts/oreshnik/hooks/pre-push','.git/hooks/pre-push');console.log('Pre-push drift hook installed.')\"",
    "deploy": "npx vercel deploy --prod --yes",
    "deploy:hook": "node -e \"fetch('https://api.vercel.com/v1/integrations/deploy/prj_flQUZNW03oOnxANUfH8pIQRvNoP7/yZQrdWODLs',{method:'POST'}).then(r=>r.json()).then(d=>{console.log(d.message||'Deploy triggered:',d.status);if(d.job)console.log('Job ID:',d.job.id)}).catch(e=>console.error(e))\"",
    "push:deploy": "git push origin master && npm run deploy",
    "goal:status": "node scripts/goal-runner/run.mjs status",
    "goal:create": "node scripts/goal-runner/run.mjs create",
    "goal:activate": "node scripts/goal-runner/run.mjs activate",
    "goal:complete": "node scripts/goal-runner/run.mjs complete",
    "goal:doctor": "node scripts/goal-runner/run.mjs doctor",
    "goal:test": "node --test scripts/goal-runner/__tests__/*.test.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "png-to-ico": "^3.0.1",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "oreshnik-cli": "file:vendor/oreshnik/oreshnik-cli-0.2.0-alpha.16-d983c051c79b99c3fcda6c4c200b7c96bda997ff.tgz",
    "pg": "^8.21.0",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  }
}
