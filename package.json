{
  "name": "heptacore",
  "version": "0.1.0",
  "private": true,
  "description": "HeptaCore multi-tenant AI marketing operating system.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npx prisma generate",
    "dev": "npm run dev -w @heptacore/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "worker": "npm run start -w @heptacore/worker",
    "worker:validate": "npm run validate -w @heptacore/worker",
    "worker:report": "npm run report -w @heptacore/worker",
    "db:generate": "npm run db:generate -w @heptacore/db",
    "db:migrate": "npm run db:migrate -w @heptacore/db",
    "oreshnik:preflight": "node scripts/oreshnik/preflight.mjs",
    "oreshnik:status": "node scripts/oreshnik/status.mjs",
    "oreshnik:sync": "node scripts/oreshnik/sync-from-mother.mjs",
    "oreshnik:sync:latest": "node scripts/oreshnik/sync-latest-mother.mjs",
    "oreshnik:close": "node scripts/oreshnik/close-sprint.mjs",
    "oreshnik:canonical": "node scripts/oreshnik/canonical-check.mjs",
    "oreshnik:zone": "node scripts/oreshnik/zone-check.mjs",
    "oreshnik:tasks": "node scripts/oreshnik/task-board.mjs",
    "oreshnik:reassign": "node scripts/oreshnik/reassign-task.mjs",
    "deploy": "npx vercel deploy --prod --yes",
    "deploy:hook": "node -e \"fetch('https://api.vercel.com/v1/integrations/deploy/prj_flQUZNW03oOnxANUfH8pIQRvNoP7/yZQrdWODLs',{method:'POST'}).then(r=>r.json()).then(d=>{console.log(d.message||'Deploy triggered:',d.status);if(d.job)console.log('Job ID:',d.job.id)}).catch(e=>console.error(e))\"",
    "push:deploy": "git push origin master && npm run deploy"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "pg": "^8.21.0"
  }
}
