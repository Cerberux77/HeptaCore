{
  "project": "heptacore",
  "gates": [
    {
      "name": "typecheck",
      "command": "npm",
      "args": [
        "run",
        "typecheck"
      ],
      "timeoutSeconds": 120
    },
    {
      "name": "build",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "timeoutSeconds": 300
    },
    {
      "name": "test",
      "command": "npm",
      "args": [
        "run",
        "test"
      ],
      "timeoutSeconds": 300
    }
  ]
}
