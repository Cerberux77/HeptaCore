# Turpial Sound — Bot RRSS Credentials Template
# ==============================================
# RUTA: .env.rrss (NO commitear este archivo lleno)
# Plantilla generada: 2026-06-01
#
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.rrss
# 2. Completar las credenciales reales
# 3. Verificar que .env.rrss esta en .gitignore
# 4. NUNCA pasar tokens, passwords o cookies por chat o repositorio

# --- Meta / Facebook ---
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Instagram (via Facebook Graph API) ---
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- YouTube / Google OAuth app (tenant authorizations stay in vault, never here) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_DEFAULT_PRIVACY_STATUS=private

# --- Meta Business Suite (manual fallback) ---
META_BUSINESS_SUITE_URL=https://business.facebook.com/latest/home

# --- Sesion cookies (para flujo manual automatizado via Puppeteer/Playwright) ---
# Solo usar si el flujo via API no esta disponible.
# Cargar estas cookies desde un vault externo, NO desde este archivo.
META_COOKIE_C_USER=
META_COOKIE_XS=

# --- WhatsApp Business (para CTAs) ---
WHATSAPP_BUSINESS_NUMBER=

# --- Marketplace Webhook (futuro) ---
MARKETPLACE_WEBHOOK_SECRET=

# --- Bot Config ---
BOT_MODE=draft
BOT_DRY_RUN=true
PUBLISH_INTERVAL_MINUTES=360
